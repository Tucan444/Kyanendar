<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Kyanendar.MVVM.ViewModels"
             xmlns:models="clr-namespace:Kyanendar.MVVM.Models"
             x:Class="Kyanendar.MVVM.Views.WeekView"
             x:DataType="viewmodels:WeekViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="20">
        <Entry
            Grid.Row="0"
            Text="{Binding Title, Mode=TwoWay}"
            Placeholder="Enter title"
            FontSize="20"
            FontAttributes="Bold" />

        <Editor
            Grid.Row="1"
            Text="{Binding Content, Mode=TwoWay}"
            Placeholder="Write content..."
            AutoSize="TextChanges"
            FontSize="16" />
    </Grid>
</ContentPage>